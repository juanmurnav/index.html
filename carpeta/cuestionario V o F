html<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Cuestionario de Verdadero o Falso</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            line-height: 1.6;
        }
        .pregunta {
            margin-bottom: 20px;
        }
        .opciones label {
            margin-right: 15px;
            cursor: pointer;
        }
        button {
            margin-top: 10px;
            padding: 8px 15px;
            cursor: pointer;
        }
        .resultado {
            margin-top: 15px;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <h2>Cuestionario Rápido</h2>

    <form id="quizForm">
        <div class="pregunta">
            <p><strong>1. ¿El Sol es una estrella?</strong></p>
            <div class="opciones">
                <label><input type="radio" name="p1" value="verdadero"> Verdadero</label>
                <label><input type="radio" name="p1" value="falso"> Falso</label>
            </div>
        </div>

        <div class="pregunta">
            <p><strong>2. ¿El agua hierve a 50 grados Celsius al nivel del mar?</strong></p>
            <div class="opciones">
                <label><input type="radio" name="p2" value="verdadero"> Verdadero</label>
                <label><input type="radio" name="p2" value="falso"> Falso</label>
            </div>
        </div>

        <button type="button" onclick="verificarRespuestas()">Enviar respuestas</button>
    </form>

    <div class="resultado" id="resultado"></div>

    <script>
        function verificarRespuestas() {
            const p1 = document.querySelector('input[name="p1"]:checked');
            const p2 = document.querySelector('input[name="p2"]:checked');
            const resultadoDiv = document.getElementById('resultado');

            if (!p1 || !p2) {
                resultadoDiv.style.color = 'red';
                resultadoDiv.textContent = 'Por favor, responde a todas las preguntas.';
                return;
            }

            let aciertos = 0;

            if (p1.value === 'verdadero') aciertos++;
            if (p2.value === 'falso') aciertos++;

            resultadoDiv.style.color = 'green';
            resultadoDiv.textContent = `Has acertado ${aciertos} de 2 preguntas.`;
        }
    </script>

</body>
</html>
