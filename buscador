# 1. Inicia Git en tu carpeta local
git init

# 2. Prepara todos tus archivos
git add .

# 3. Guarda este estado con un mensaje descriptivo
git commit -m "Mi primer envío"

# 4. Crea tu repositorio en la web de GitHub (vacío, sin añadir archivo README)
# 5. Vincula tu carpeta local con el repositorio web que creaste
git remote add origin URL_DE_TU_REPOSITORIO_EN_GITHUB

# 6. Cambia el nombre de la rama principal a 'main'
git branch -M main

# 7. Sube definitivamente todo tu código a internet
git push -u origin main
